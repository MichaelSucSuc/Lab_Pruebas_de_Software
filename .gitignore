__pycache__/
*.py[cod]
*.so
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/

# Node.js
node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log
.pnpm-debug.log
.npm
.yarn

# Java
*.class
*.jar
*.war
*.ear
hs_err_pid*

# .NET
bin/
obj/
*.suo
*.user

# ---------------------------------
