# ---------------------------------
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IntelliJ / WebStorm
.idea/
*.iml
*.iws

# Vim
[._]*.s[a-w][a-z]
[._]s[a-w][a-z]

# ---------------------------------
# Logs y archivos temporales
# ---------------------------------
*.log
logs/
*.out
*.tmp

# ---------------------------------
# Builds y compilaciones
# ---------------------------------
/dist/
/build/
/out/
*.exe
*.dll
*.so
*.dylib

# ---------------------------------
# Variables de entorno
# ---------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---------------------------------
# Archivos generados por herramientas
# ---------------------------------
coverage/
.nyc_output/

# ---------------------------------
# Archivos de Git
# ---------------------------------
# Evita ignorar el propio .gitignore si ya fue rastreado
# (útil solo si fue creado manualmente y no debe subirse)
#.gitignore

# Archivo de exclusión local (no se comparte)
.git/info/exclude   
